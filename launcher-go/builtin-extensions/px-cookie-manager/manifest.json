{
  "manifest_version": 3,
  "name": "PX Cookie Manager",
  "description": "Import, export, and manage cookies for PersonaX profiles",
  "version": "1.0.0",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
