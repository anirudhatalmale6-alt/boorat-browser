{
  "manifest_version": 3,
  "name": "PX Proxy Tester",
  "description": "Test proxy connection, check IP, location, and detection status",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://ip-api.com/*",
    "https://ipapi.co/*",
    "https://check.torproject.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
